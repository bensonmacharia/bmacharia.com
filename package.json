{
  "name": "tailwind-nextjs-starter-blog",
  "version": "2.4.0",
  "private": true,
  "scripts": {
    "start": "next dev",
    "dev": "cross-env INIT_CWD=$PWD next dev",
    "build": "cross-env INIT_CWD=$PWD next build && cross-env NODE_OPTIONS='--experimental-json-modules' node ./scripts/postbuild.mjs",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "next lint --fix --dir pages --dir app --dir components --dir lib --dir layouts --dir scripts",
    "spellcheck": "spellchecker --config .spellcheckerrc.json",
    "spellcheck:report": "spellchecker --config .spellcheckerrc.json > spellcheck-results.txt 2>&1 || true",
    "spellcheck:fix": "spellchecker --config .spellcheckerrc.json --generate-dictionary",
    "spellcheck:ci": "spellchecker --config .spellcheckerrc.json --quiet --no-suggestions > spellcheck-results.txt 2>&1 && echo 'Spell check passed' || (echo 'Spell check failed. See spellcheck-results.txt for details' && exit 1)",
    "cspell": "cspell lint",
    "cspell:check": "cspell lint '**/*.{md,mdx,tsx,ts,js,jsx}'",
    "cspell:report": "cspell lint '**/*.{md,mdx,tsx,ts,js,jsx}' > cspell-results.txt 2>&1 || true",
    "prepare": "husky"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@headlessui/react": "2.2.9",
    "@next/bundle-analyzer": "15.5.12",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@wojtekmaj/react-hooks": "^1.18.0",
    "autoprefixer": "^10.4.13",
    "contentlayer2": "0.5.8",
    "esbuild": "0.27.3",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "hast-util-from-html-isomorphic": "^2.0.0",
    "image-size": "2.0.2",
    "lucide-react": "^0.424.0",
    "next": "15.5.12",
    "next-contentlayer2": "0.5.8",
    "next-themes": "^0.4.6",
    "pliny": "0.4.1",
    "postcss": "^8.5.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-pdf": "^7.7.1",
    "react-rough-notation": "^1.0.5",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-citation": "^2.3.2",
    "rehype-katex": "^7.0.1",
    "rehype-preset-minify": "7.0.1",
    "rehype-prism-plus": "^2.0.2",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^4.1.18",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.18.0",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/mdx": "^2.0.13",
    "@types/react": "^19.2.13",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "copy-webpack-plugin": "^12.0.2",
    "cross-env": "^10.1.0",
    "cspell": "^9.1.3",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.5.12",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "raw-loader": "^4.0.2",
    "spellchecker-cli": "^6.2.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ],
    "*.+(md|mdx|tsx|ts)": [
      "cspell lint --no-must-find-files"
    ]
  },
  "packageManager": "yarn@3.6.1"
}
